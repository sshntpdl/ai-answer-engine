generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Search {
  id        String    @id @default(cuid())
  query     String
  answer    String
  sources   Source[]
  followUps FollowUp[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}

model Source {
  id       String  @id @default(cuid())
  url      String
  title    String
  snippet  String
  favicon  String?
  searchId String
  search   Search  @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([searchId])
}

model FollowUp {
  id        String   @id @default(cuid())
  question  String
  answer    String
  searchId  String
  search    Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([searchId])
}
